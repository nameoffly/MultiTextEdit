# Copy this file to .env and fill in your own values.
# The OpenAI Responses API endpoint is used by default.

OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_URL=https://api.openai.com/v1/responses
OPENAI_MODEL=gpt-5.4
OPENAI_TIMEOUT=900

# Response parsing mode for the gateway:
#   auto      — try non-stream first, fall back to SSE stream parsing on empty response
#   nonstream — only accept a non-streaming JSON body
#   stream    — request and parse SSE stream events
OPENAI_RESPONSE_MODE=auto
